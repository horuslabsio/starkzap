{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "starkzap": ["../../src/index.ts"],
      "@/*": ["../../src/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.d.ts"]
}
